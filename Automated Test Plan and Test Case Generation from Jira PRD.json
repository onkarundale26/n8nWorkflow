      "parameters": {
        "jsCode": "const rawOutput = $node[\"Generate Test Cases\"].json[\"output\"];\nconst testCases = JSON.parse(rawOutput);\n\nreturn testCases.map(tc => {\n  return {\n    json: {\n      \"ID\": tc.testCaseId,\n      \"Name\": tc.testCaseName,\n      \"Preconditions\": tc.preconditions,\n      \"Steps\": Array.isArray(tc.testSteps) ? tc.testSteps.join('\\n') : tc.testSteps,\n      \"Expected Results\": tc.expectedResults,\n      \"Priority\": tc.priority\n    }\n  };\n});"
      },

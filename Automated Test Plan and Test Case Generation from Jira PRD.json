      "parameters": {
        "promptType": "define",
        "text": "=You are a QA Expert. Based on the following PRD content, create a comprehensive test plan document.\n\n### PROJECT CONTEXT:\nProject Name: Style Haven\nJira Issue: {{ $node[\"Extract PRD URL\"].json[\"jiraKey\"] }}\nSummary: {{ $node[\"Extract PRD URL\"].json[\"summary\"] }}\n\n### PRD CONTENT:\n{{ $node[\"Extract from File\"].json[\"text\"] }}\n\n### INSTRUCTIONS:\n- Fill in all project details using the context provided above.\n- DO NOT use placeholders like [Project Name] or [Jira ID].\n- Format the output in clean Markdown.",
        "options": {
          "systemMessage": "You are a QA expert. Generate a detailed test plan that includes: test objectives, scope, test strategy, test environment requirements, test schedule, and risk assessment. Format the output as a well-structured document."
        }
      },

    {
      "parameters": {
        "jsCode": "let aiOutput = $node[\"Test Cases Generator\"].json[\"output\"].trim();\n\n// 1. Fix common AI formatting issues (remove markdown backticks if present)\naiOutput = aiOutput.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n\n// 2. Handle truncated JSON (The \"Repair\" Logic)\nif (!aiOutput.endsWith(']')) {\n    // Find the last complete object and cut off the trailing junk\n    const lastCompleteIndex = aiOutput.lastIndexOf('}');\n    if (lastCompleteIndex !== -1) {\n        aiOutput = aiOutput.substring(0, lastCompleteIndex + 1) + ']';\n    }\n}\n\ntry {\n    const testCases = JSON.parse(aiOutput);\n    return testCases.map(tc => ({ json: tc }));\n} catch (e) {\n    // If it still fails, return an error object so the workflow doesn't just stop\n    return [{ json: { error: \"JSON still invalid\", raw: aiOutput.substring(0, 100) } }];\n}"
      },
